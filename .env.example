# ─────────────────────────────────────────────────────────────────────────────
# API Genie — environment configuration
# Copy this file to `.env` and adjust. Or run `./scripts/bootstrap.sh` for an
# interactive first-time setup that writes `.env` for you.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public-facing identity ───────────────────────────────────────────────────
# DNS hostname collectors will use to reach this stack.
# Used by: nginx server_name, TLS cert SAN, Kafka advertised listeners,
# Pub/Sub OAuth token URI, all source curl examples in /admin.
APIGENIE_DOMAIN=apigenie.example.com

# Where Kafka tells external clients to connect for advertised listeners.
# 99% of the time this should equal APIGENIE_DOMAIN. Override only if the
# Kafka external listener is reachable on a different hostname (split-horizon
# DNS, separate ALB, etc.).
APIGENIE_KAFKA_ADVERTISED_HOST=${APIGENIE_DOMAIN}

# ── TLS ──────────────────────────────────────────────────────────────────────
# How the stack obtains its certificate.
#   self-signed   — bootstrap.sh generates a local CA-less cert. Browsers will
#                   warn; collectors need TLS verify off or the CA installed.
#                   Good for: lab, internal demos, localhost.
#   letsencrypt   — certbot in the certbot sidecar runs the HTTP-01 challenge
#                   on port 80. Requires the host to be publicly reachable on
#                   80 + DNS pointing at it. Good for: production, public demos.
#   provided      — you put your own certs into ./certs/${APIGENIE_DOMAIN}/
#                   as fullchain.pem and privkey.pem. We don't touch them.
APIGENIE_TLS_MODE=self-signed

# Email for Let's Encrypt expiry / revocation notices. Required when
# APIGENIE_TLS_MODE=letsencrypt.
APIGENIE_TLS_EMAIL=

# Set to "letsencrypt" to activate the in-stack certbot manager that issues
# and auto-renews the cert. Leave empty for self-signed / provided modes.
# Must match APIGENIE_TLS_MODE for letsencrypt to actually run.
COMPOSE_PROFILES=

# ── Admin credentials ────────────────────────────────────────────────────────
# Username for /admin/login.
ADMIN_USERNAME=admin

# Plaintext fallback. INSECURE — used only when ADMIN_PASSWORD_HASH is empty.
# bootstrap.sh and the in-app "change password" flow will set the hash and
# blank this out.
ADMIN_PASSWORD=apigenie

# PBKDF2-HMAC-SHA256 hash, format: pbkdf2_sha256$<iters>$<salt_hex>$<hash_hex>
# When non-empty, takes precedence over ADMIN_PASSWORD.
# Use `python3 scripts/hash_password.py` to generate one, or change-pwd in /admin.
ADMIN_PASSWORD_HASH=

# ── Admin GeoMap (optional) ──────────────────────────────────────────────────
# Free MaxMind license key. When set, ./scripts/refresh-geoip.sh downloads
# GeoLite2-City.mmdb into ./data/geoip/ and the admin GeoMap tab uses offline
# lookups (fast, unlimited). Without it, ApiGenie falls back to ip-api.com
# (45 req/min, requires outbound HTTPS).
# Get a free key at https://www.maxmind.com/en/geolite2/signup .
MAXMIND_LICENSE_KEY=

# Cap on the (client_ip, source) aggregation table that powers the Sankey
# and GeoMap views. Oldest entries are evicted when this is exceeded.
APIGENIE_AGG_CAP=5000

# ── FastAPI server ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PUBLISHERS_ENABLED=true

# ── GCP Pub/Sub emulator ─────────────────────────────────────────────────────
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
GCP_PROJECT_ID=obs-test
PUBSUB_TOPIC_ID=audit-logs
PUBSUB_SUBSCRIPTION_ID=audit-logs-sub
PUBSUB_PUBLISH_INTERVAL=10
PUBSUB_BATCH_SIZE=5

# ── Kafka / Azure Event Hubs emulator ────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=azure-platform-logs
KAFKA_PUBLISH_INTERVAL=10
KAFKA_BATCH_SIZE=5

# ── Backward-compat aliases (legacy variable names — do not edit) ────────────
# Kept so existing docker-compose.yaml interpolations keep working.
PUBLIC_HOSTNAME=${APIGENIE_KAFKA_ADVERTISED_HOST}
