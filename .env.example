# ApiGenie environment variables — copy to .env and adjust

# Server
LOG_LEVEL=INFO
PUBLISHERS_ENABLED=true

# GCP Pub/Sub emulator
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
GCP_PROJECT_ID=apigenie-project
PUBSUB_TOPIC_ID=audit-logs
PUBSUB_SUBSCRIPTION_ID=audit-logs-sub
PUBSUB_PUBLISH_INTERVAL=10
PUBSUB_BATCH_SIZE=5

# Kafka / Azure Event Hubs emulator
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=azure-platform-logs
KAFKA_PUBLISH_INTERVAL=10
KAFKA_BATCH_SIZE=5

# External hostname (used in Kafka advertised listeners)
PUBLIC_HOSTNAME=apigenie.roarinpenguin.com
